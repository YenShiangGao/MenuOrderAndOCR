# ============================================
# 資料庫(Supabase Postgres)
# ============================================
# Supabase 的 Direct connection(port 5432)。M1 流量小,單一 URL 即可。
# 若未來上 Vercel 出現連線數爆炸,再切換到 Pooler URL (port 6543)。
# 取得方式:Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ============================================
# Supabase(Storage / 未來功能用)
# ============================================
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ============================================
# Session(iron-session 用,加密 cookie)
# ============================================
# 產生方式:openssl rand -base64 48
SESSION_SECRET="REPLACE_WITH_RANDOM_48_BYTE_BASE64"

# ============================================
# Seed(可選,不設會用預設值)
# ============================================
# SEED_ADMIN_EMAIL="owner@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe123!"

NODE_ENV="development"
